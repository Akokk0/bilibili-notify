{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"root": true,
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/lib",
			"!**/dist",
			"**/*.vue",
			"!**/src/static",
			"!.changeset",
			"!**/.interface",
			"!.bn-design",
			"!.claude",
			"!data",
			"!apps/**/data",
			"!apps/desktop/src-tauri/gen",
			"!apps/desktop/src-tauri/resources",
			"!apps/desktop/src-tauri/target",
			"!astrbot/core/sidecar/app",
			"!astrbot/core/pages",
			"!astrbot/core/sidecar/state",
			"!astrbot/core/sidecar/logs"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"css": {
		"parser": { "tailwindDirectives": true }
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
