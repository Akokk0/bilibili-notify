{
	"name": "koishi-plugin-bilibili-notify-image",
	"version": "0.1.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Akokk0/bilibili-notify"
	},
	"author": {
		"name": "Akokko",
		"email": "admin@akokko.com"
	},
	"description": "Bilibili 通知图片渲染插件（bilibili-notify 可选插件）",
	"type": "module",
	"files": [
		"lib"
	],
	"license": "MIT",
	"keywords": [
		"chatbot",
		"koishi",
		"plugin",
		"bilibili",
		"bilibili-notify"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@bilibili-notify/api": "workspace:^",
		"@unocss/core": "^66.6.8",
		"@unocss/preset-wind4": "^66.6.8",
		"@vue/server-renderer": "^3.5.32",
		"blive-message-listener": "^0.5.3",
		"jsdom": "^26.1.0",
		"luxon": "^3.5.0",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@types/jsdom": "^21.1.7",
		"@types/luxon": "^3.4.2",
		"vitest": "^4.1.3"
	},
	"peerDependencies": {
		"koishi": "^4.18.11",
		"koishi-plugin-puppeteer": "*"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"koishi": {
		"service": {
			"required": [
				"puppeteer"
			],
			"provides": [
				"bilibili-notify-image"
			]
		},
		"description": {
			"zh": "Bilibili 通知图片渲染插件"
		}
	},
	"main": "./lib/index.cjs",
	"types": "./lib/index.d.cts",
	"exports": {
		".": {
			"import": "./lib/index.mjs",
			"require": "./lib/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"inlinedDependencies": {
		"@standard-schema/spec": "1.1.0",
		"cosmokit": "1.8.1",
		"schemastery": "3.18.0"
	},
	"module": "./lib/index.mjs"
}
