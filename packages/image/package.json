{
	"name": "koishi-plugin-bilibili-notify-image",
	"version": "0.0.3-alpha.2",
	"description": "Bilibili 通知图片渲染插件（bilibili-notify 可选插件）",
	"type": "module",
	"files": [
		"lib"
	],
	"license": "MIT",
	"keywords": [
		"chatbot",
		"koishi",
		"plugin",
		"bilibili",
		"bilibili-notify"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@bilibili-notify/api": "workspace:^",
		"blive-message-listener": "^0.5.3",
		"jsdom": "^26.1.0",
		"luxon": "^3.5.0"
	},
	"devDependencies": {
		"@types/jsdom": "^21.1.7",
		"@types/luxon": "^3.4.2"
	},
	"peerDependencies": {
		"koishi": "^4.18.11",
		"koishi-plugin-puppeteer": "*"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"koishi": {
		"service": {
			"required": [
				"puppeteer"
			],
			"provides": [
				"bilibili-notify-image"
			]
		},
		"description": {
			"zh": "Bilibili 通知图片渲染插件"
		}
	},
	"main": "./lib/index.cjs",
	"types": "./lib/index.d.cts",
	"exports": {
		".": {
			"import": "./lib/index.mjs",
			"require": "./lib/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"inlinedDependencies": {
		"@standard-schema/spec": "1.1.0",
		"cosmokit": "1.8.1",
		"schemastery": "3.18.0"
	},
	"module": "./lib/index.mjs"
}
