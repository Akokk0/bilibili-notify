# Build outputs — rebuilt inside the image.
**/lib
**/dist

# All node_modules — populated by yarn/pnpm in the builder stage.
**/node_modules

# Local pnpm store + yarn caches.
.yarn
.pnpm-store

# Repo metadata + editor noise.
.git
.github
.gitignore
.gitattributes
.idea
.vscode
.DS_Store
*.swp

# Markdown / design assets / logs not needed at build time.
**/*.md
!.changeset/*.md
!apps/CHANGELOG.md
.bn-design

# Local-only state and secrets from previous runs.
.env
.env.*
**/.env
**/.env.*
**/master.key
**/*.pem
**/*.key
**/*.enc
data/**
logs/**
apps/server/data
apps/server/data/**
apps/server/bn-data
apps/server/bn-data/**
apps/server/logs
apps/server/logs/**
apps/server/bn.config.yaml
apps/server/bn.config.yml
apps/server/bn.config.json

# Test snapshots / build cache.
**/tsconfig.tsbuildinfo
**/.eslintcache
**/coverage

# Lefthook output.
.lefthook
